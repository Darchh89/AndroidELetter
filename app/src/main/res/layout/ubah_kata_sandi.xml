<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvBackChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="‹ Kembali ke Halaman Utama"
        android:textColor="#C4C4C4"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTitleChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Ubah Kata Sandi"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvBackChange" />

    <TextView
        android:id="@+id/tvDescriptionChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Masukkan kata sandi baru anda"
        android:textColor="#555555"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitleChange" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutSandiBaru"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="#CCCCCC"
        app:hintEnabled="false"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#FF9F43"
        app:startIconDrawable="@drawable/kotak_email_oren"
        app:layout_constraintTop_toBottomOf="@+id/tvDescriptionChange">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSandiBaru"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Masukkan Kata Sandi"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textSize="14sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutKonfirmasiSandi"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="#CCCCCC"
        app:hintEnabled="false"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#FF9F43"
        app:startIconDrawable="@drawable/kotak_email_oren"
        app:layout_constraintTop_toBottomOf="@+id/layoutSandiBaru">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etKonfirmasiSandi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Konfirmasi Kata Sandi"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:textSize="14sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUbah"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:text="Ubah"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FF9F43"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutKonfirmasiSandi" />

</androidx.constraintlayout.widget.ConstraintLayout>
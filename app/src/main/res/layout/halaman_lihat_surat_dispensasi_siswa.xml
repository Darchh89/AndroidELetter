                    <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" app:cardBackgroundColor="#FFCDD2" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:layout_constraintBottom_toBottomOf="@+id/title_d2" app:layout_constraintStart_toEndOf="@+id/title_d2" app:layout_constraintTop_toTopOf="@+id/title_d2">

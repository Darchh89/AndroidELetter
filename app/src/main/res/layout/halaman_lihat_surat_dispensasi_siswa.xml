                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="No. Surat: SRT-1763363016510" android:textColor="#424242" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@+id/tgl_m2" />
                </androidx.constraintlayout.widget.ConstraintLayout>

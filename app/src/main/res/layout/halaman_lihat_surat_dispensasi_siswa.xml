                    <TextView android:id="@+id/tgl_s2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:drawablePadding="8dp" android:text="Diajukan: 18 November 2025 pukul 13.00" android:textColor="#616161" android:textSize="12sp" app:drawableStartCompat="@drawable/icon_tanggal_biru" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/pengirim_s2" />


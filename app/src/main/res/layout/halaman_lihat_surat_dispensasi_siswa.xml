                    <TextView android:id="@+id/pengirim_m2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:drawablePadding="8dp" android:text="Paskibra" android:textColor="#616161" android:textSize="12sp" app:drawableStartCompat="@drawable/user_abu_putih" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/title_m2" />


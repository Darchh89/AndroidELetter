                    <TextView android:id="@+id/tgl_d2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:drawablePadding="8dp" android:text="Diajukan: 10 November 2025 pukul 08.00" android:textColor="#616161" android:textSize="12sp" app:drawableStartCompat="@drawable/icon_tanggal_biru" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/pengirim_d2" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="No. Surat: SRT-1763363016512" android:textColor="#424242" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@+id/tgl_d2" />

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="‹ Kembali ke Halaman Utama"
        android:textColor="#C4C4C4"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTitleOTP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Verifikasi OTP"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvBack" />

    <TextView
        android:id="@+id/tvDescriptionOTP"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Ketik kode verifikasi yang telah dikirim ke\nalamat email Anda: tambang@gmail.com"
        android:textColor="#555555"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitleOTP" />

    <LinearLayout
        android:id="@+id/layoutOTP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tvDescriptionOTP">

        <EditText
            android:id="@+id/otp1"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp2"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp3"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp4"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp5"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp6"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:background="@drawable/frame_kotak"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKonfirmasi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:text="Konfirmasi"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FF9F43"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutOTP" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnKonfirmasi">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tidak menerima kode? "
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvKirimUlang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kirim ulang"
            android:textColor="#FF9F43"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>